---
import media from '../../data/media.json';
---

<header class="fixed top-0 right-0 left-0 z-50">
  <div class="border-b border-champagne/50 bg-ivory/90 backdrop-blur-lg" id="header-inner">
    <div class="container-salon flex items-center justify-between px-5 py-3.5 sm:py-4">
      <a href="/" class="shrink-0">
        <img src={media.logo} alt={media.logoAlt} class="h-8 w-auto sm:h-9" width="160" height="36" />
      </a>
      <nav class="hidden items-center gap-6 lg:flex">
        <a href="/#reviews" class="text-[11px] font-semibold tracking-[0.14em] text-charcoal uppercase hover:text-rose-gold-dark">Reviews</a>
        <a href="/#transformations" class="text-[11px] font-semibold tracking-[0.14em] text-charcoal uppercase hover:text-rose-gold-dark">Before & After</a>
        <a href="/#team" class="text-[11px] font-semibold tracking-[0.14em] text-charcoal uppercase hover:text-rose-gold-dark">About</a>
        <a href="/#packages" class="text-[11px] font-semibold tracking-[0.14em] text-charcoal uppercase hover:text-rose-gold-dark">Services</a>
        <a href="/projects" class="text-[11px] font-semibold tracking-[0.14em] text-charcoal uppercase hover:text-rose-gold-dark">Projects</a>
        <a href="/blog" class="text-[11px] font-semibold tracking-[0.14em] text-charcoal uppercase hover:text-rose-gold-dark">Blog</a>
        <a href="/#contact" class="btn-primary !min-h-[40px] !px-5 !py-2 !text-[10px]">Free Review</a>
      </nav>
      <button id="mobile-menu-btn" class="flex h-11 w-11 items-center justify-center lg:hidden" aria-label="Menu">
        <svg class="h-5 w-5 text-charcoal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16" />
        </svg>
      </button>
    </div>
  </div>
  <div id="mobile-menu" class="hidden border-b border-champagne/80 bg-ivory/98 shadow-lg backdrop-blur-xl lg:hidden">
    <nav class="flex flex-col px-5 pb-6 pt-2">
      <a href="/#reviews" class="border-b border-champagne/40 py-4 text-[15px] font-medium text-charcoal hover:text-rose-gold-dark">Reviews</a>
      <a href="/#transformations" class="border-b border-champagne/40 py-4 text-[15px] font-medium text-charcoal hover:text-rose-gold-dark">Before & After</a>
      <a href="/#team" class="border-b border-champagne/40 py-4 text-[15px] font-medium text-charcoal hover:text-rose-gold-dark">About</a>
      <a href="/#packages" class="border-b border-champagne/40 py-4 text-[15px] font-medium text-charcoal hover:text-rose-gold-dark">Services</a>
      <a href="/projects" class="border-b border-champagne/40 py-4 text-[15px] font-medium text-charcoal hover:text-rose-gold-dark">Projects</a>
      <a href="/blog" class="border-b border-champagne/40 py-4 text-[15px] font-medium text-charcoal hover:text-rose-gold-dark">Blog</a>
      <a href="/#contact" class="btn-whatsapp mt-5 w-full text-center">Free WhatsApp Review</a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  menu?.querySelectorAll('a').forEach((l) => l.addEventListener('click', () => menu?.classList.add('hidden')));
</script>
