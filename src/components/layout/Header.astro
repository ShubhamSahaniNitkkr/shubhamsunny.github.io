---
import media from '../../data/media.json';

const exploreLinks = [
  { href: '/projects', label: 'Projects' },
  { href: '/templates', label: 'Templates' },
  { href: '/products', label: 'Products' },
  { href: '/blog', label: 'Blog' },
];
---

<header class="fixed top-0 right-0 left-0 z-50" id="site-header">
  <div class="border-b border-zinc-200 bg-white/90 backdrop-blur-xl" id="header-inner">
    <div class="mx-auto flex w-full max-w-7xl items-center justify-between px-4 py-3.5 sm:px-6">
      <a href="/" class="shrink-0">
        <img src={media.logo} alt={media.logoAlt} class="h-7 w-auto sm:h-8" width="220" height="36" />
      </a>
      <nav class="hidden items-center gap-6 lg:flex">
        <a href="/#about" class="nav-link">About</a>
        <a href="/#services" class="nav-link">Services</a>
        <a href="/#team" class="nav-link">Team</a>
        <div class="nav-dropdown group relative">
          <button type="button" class="nav-link inline-flex items-center gap-1" aria-haspopup="true" aria-expanded="false" id="explore-dropdown-btn">
            Explore
            <svg class="h-4 w-4 transition group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="nav-dropdown-menu invisible absolute left-1/2 top-full z-50 mt-2 w-48 -translate-x-1/2 rounded-xl border border-zinc-200 bg-white py-2 opacity-0 shadow-lg transition-all group-hover:visible group-hover:opacity-100">
            {exploreLinks.map((link) => (
              <a href={link.href} class="block px-4 py-2.5 text-sm font-medium text-zinc-600 transition hover:bg-zinc-50 hover:text-blue-600">
                {link.label}
              </a>
            ))}
          </div>
        </div>
        <a href="/#contact" class="btn-accent !min-h-[40px] !px-5 !py-2 !text-xs">Contact</a>
      </nav>
      <button id="mobile-menu-btn" class="flex h-10 w-10 items-center justify-center rounded-lg border border-zinc-200 lg:hidden" aria-label="Menu">
        <svg class="h-5 w-5 text-zinc-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16" />
        </svg>
      </button>
    </div>
  </div>
  <div id="mobile-menu" class="hidden border-b border-zinc-200 bg-white shadow-lg lg:hidden">
    <nav class="flex flex-col px-5 pb-5 pt-1">
      <a href="/#about" class="mobile-nav-link">About</a>
      <a href="/#reviews" class="mobile-nav-link">Reviews</a>
      <a href="/#services" class="mobile-nav-link">Services</a>
      <a href="/#team" class="mobile-nav-link">Team</a>
      <p class="mt-3 mb-1 px-1 text-[10px] font-bold uppercase tracking-wider text-zinc-400">Explore</p>
      {exploreLinks.map((link) => (
        <a href={link.href} class="mobile-nav-link !pl-4">{link.label}</a>
      ))}
      <a href="/#faq" class="mobile-nav-link">FAQ</a>
      <a href="/#contact" class="btn-accent mt-4 w-full text-center">Contact</a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  menu?.querySelectorAll('a').forEach((l) => l.addEventListener('click', () => menu?.classList.add('hidden')));
</script>

<style>
  .nav-dropdown-menu {
    transform: translateX(-50%) translateY(4px);
  }
  .nav-dropdown:hover .nav-dropdown-menu,
  .nav-dropdown:focus-within .nav-dropdown-menu {
    visibility: visible;
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
</style>
