---
import { siteConfig } from '../../lib/utils';
import social from '../../data/social.json';
import media from '../../data/media.json';
import legalPages from '../../data/legal-pages.json';
import type { LegalPage } from '../../types';

const legal = legalPages as LegalPage[];
---

<footer class="border-t border-zinc-200 bg-zinc-50 text-zinc-600">
  <div class="mx-auto max-w-7xl section-padding !py-12 max-sm:!pb-24 sm:!py-16">
    <div class="grid grid-cols-1 gap-8 max-sm:text-center sm:grid-cols-2 sm:gap-10 lg:grid-cols-5">
      <div class="sm:col-span-2 lg:col-span-1">
        <img src={media.logo} alt={media.logoAlt} class="mx-auto h-8 w-auto sm:mx-0" loading="lazy" />
        <p class="mx-auto mt-4 max-w-xs text-sm leading-relaxed text-zinc-600 sm:mx-0">
          Websites, data &amp; software — built to help your business grow faster.
        </p>
        <p class="mt-2 text-xs text-zinc-400">{siteConfig.stats.yearsExperience}+ years · {siteConfig.stats.projectsDelivered}+ projects delivered</p>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-zinc-900">Services</p>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/#services" class="hover:text-blue-600">Website Modernization</a></li>
          <li><a href="/#services" class="hover:text-blue-600">Data Scraping</a></li>
          <li><a href="/#services" class="hover:text-blue-600">Custom Software</a></li>
          <li><a href="/templates" class="hover:text-blue-600">Free Templates</a></li>
        </ul>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-zinc-900">Links</p>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/projects" class="hover:text-blue-600">Projects</a></li>
          <li><a href="/blog" class="hover:text-blue-600">Blog</a></li>
          <li><a href="/#use-cases" class="hover:text-blue-600">Use Cases</a></li>
          <li><a href="/#faq" class="hover:text-blue-600">FAQ</a></li>
          <li><a href={social.linkedin.url} target="_blank" rel="noopener" class="hover:text-blue-600">LinkedIn</a></li>
        </ul>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-zinc-900">Legal</p>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/legal" class="hover:text-blue-600">All policies</a></li>
          {legal.slice(0, 4).map((page) => (
            <li><a href={`/legal/${page.slug}`} class="hover:text-blue-600">{page.shortTitle}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-zinc-900">Contact</p>
        <ul class="mt-3 space-y-2 text-sm">
          <li>{siteConfig.location}</li>
          <li><a href="/#contact" class="hover:text-blue-600">{siteConfig.email}</a></li>
          <li><a href={`tel:${siteConfig.phone.replace(/\s/g, '')}`} class="hover:text-blue-600">{siteConfig.phone}</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-10 border-t border-zinc-200 pt-6 text-center text-xs text-zinc-400">
      <p>
        © {new Date().getFullYear()} {siteConfig.brand}. All rights reserved.
        {' '}
        <a href="/legal/privacy-policy" class="hover:text-zinc-600">Privacy</a>
        {' · '}
        <a href="/legal/terms-of-service" class="hover:text-zinc-600">Terms</a>
        {' · '}
        <a href="/legal/cookie-policy" class="hover:text-zinc-600">Cookies</a>
        {' · '}
        <button type="button" id="cookie-settings-link" class="hover:text-zinc-600">Cookie settings</button>
      </p>
    </div>
    <script>
      document.getElementById('cookie-settings-link')?.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('ss-open-cookie-settings'));
      });
    </script>
  </div>
</footer>
