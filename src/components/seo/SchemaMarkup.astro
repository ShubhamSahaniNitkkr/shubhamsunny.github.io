---
import { getAllSchemas, type SchemaPageType, type BlogPostSchemaInput } from '../../lib/schema';

interface Props {
  type?: SchemaPageType;
  serviceName?: string;
  serviceDescription?: string;
  pageUrl?: string;
  pageTitle?: string;
  pageDescription?: string;
  blogPost?: BlogPostSchemaInput;
  blogPosts?: BlogPostSchemaInput[];
}

const {
  type = 'page',
  serviceName,
  serviceDescription,
  pageUrl,
  pageTitle,
  pageDescription,
  blogPost,
  blogPosts,
} = Astro.props;

const schemas = getAllSchemas({
  type,
  serviceName,
  serviceDescription,
  pageUrl,
  pageTitle,
  pageDescription,
  blogPost,
  blogPosts,
});
---

{schemas.map((schema) => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
