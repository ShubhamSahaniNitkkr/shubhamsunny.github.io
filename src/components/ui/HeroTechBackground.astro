---
/** Subtle animated tech grid for the hero — pure CSS, lightweight */
---

<div class="hero-tech-bg pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
  <div class="hero-tech-grid"></div>
  <div class="hero-tech-orb hero-tech-orb--1"></div>
  <div class="hero-tech-orb hero-tech-orb--2"></div>
  <svg class="hero-tech-lines" viewBox="0 0 1440 800" preserveAspectRatio="xMidYMid slice">
    <path class="hero-tech-line" d="M0 400 Q360 300 720 400 T1440 400" fill="none" stroke="url(#lineGrad)" stroke-width="1"/>
    <path class="hero-tech-line hero-tech-line--delay" d="M0 500 Q360 600 720 500 T1440 500" fill="none" stroke="url(#lineGrad)" stroke-width="1"/>
    <defs>
      <linearGradient id="lineGrad" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#7856FF" stop-opacity="0"/>
        <stop offset="50%" stop-color="#7856FF" stop-opacity="0.25"/>
        <stop offset="100%" stop-color="#7856FF" stop-opacity="0"/>
      </linearGradient>
    </defs>
  </svg>
  <div class="hero-tech-dots">
    {Array.from({ length: 8 }).map((_, i) => (
      <span class="hero-tech-dot" style={`--i: ${i}`}></span>
    ))}
  </div>
</div>
