---
interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  align?: 'center' | 'left';
  light?: boolean;
}

const { label, title, subtitle, align = 'center', light = false } = Astro.props;
const alignClass = align === 'center' ? 'text-center items-center' : 'text-left items-start';
const titleColor = light ? 'text-ivory' : 'text-charcoal';
const subColor = light ? 'text-ivory/65' : 'text-muted';
---

<div class={`mb-10 flex flex-col sm:mb-12 ${alignClass}`}>
  {label && <p class="label">{label}</p>}
  <div class={`divider mt-3 ${align === 'center' ? 'mx-auto' : ''}`}></div>
  <h2 class={`font-display mt-4 text-3xl font-semibold sm:text-4xl ${titleColor}`}>{title}</h2>
  {subtitle && <p class={`mt-3 max-w-lg text-sm leading-relaxed sm:text-base ${subColor}`}>{subtitle}</p>}
</div>
