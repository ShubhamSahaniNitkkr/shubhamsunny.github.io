---
interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  align?: 'center' | 'left';
  light?: boolean;
  dark?: boolean;
  compact?: boolean;
}

const { label, title, subtitle, align = 'center', light = false, dark = false, compact = false } = Astro.props;
const alignClass = align === 'center' ? 'text-center items-center' : 'text-left items-start';
const titleColor = dark || light ? 'text-ivory' : 'text-charcoal';
const subColor = dark || light ? 'text-ivory/65' : 'text-muted';
const labelColor = dark ? 'text-accent' : '';
---

<div class:list={['flex flex-col', compact ? 'mb-4 sm:mb-5' : 'mb-10 sm:mb-12', alignClass]}>
  {label && <p class:list={['label', labelColor]}>{label}</p>}
  {!dark && <div class={`divider mt-3 ${align === 'center' ? 'mx-auto' : ''}`}></div>}
  {dark && <div class={`mt-3 h-0.5 w-10 rounded-full bg-accent ${align === 'center' ? 'mx-auto' : ''}`}></div>}
  <h2 class:list={['font-display mt-3 font-semibold', compact ? 'text-2xl sm:text-3xl' : 'mt-4 text-3xl sm:text-4xl', titleColor]}>{title}</h2>
  {subtitle && <p class:list={['mt-2 max-w-lg leading-relaxed', compact ? 'text-xs sm:text-sm' : 'mt-3 text-sm sm:text-base', subColor]}>{subtitle}</p>}
</div>
