---
import { getCloudinaryUrl } from '../../lib/utils';

interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
}

const { src, alt, width = 640, height = 800 } = Astro.props;
const imgSrc = getCloudinaryUrl(src, width, height);
---

<div class="portrait-wrap relative mx-auto w-full max-w-[340px] lg:max-w-none">
  <div class="portrait-glow absolute -inset-4 rounded-[2rem] opacity-60 blur-2xl" aria-hidden="true"></div>
  <div class="portrait-frame relative overflow-hidden rounded-[1.75rem] p-[2px]">
    <div class="portrait-inner overflow-hidden rounded-[1.65rem] bg-[#12121a]">
      <img
        src={imgSrc}
        alt={alt}
        class="aspect-[4/5] w-full object-cover object-top"
        width={width}
        height={height}
        fetchpriority="high"
      />
      <div class="portrait-shimmer pointer-events-none absolute inset-0" aria-hidden="true"></div>
    </div>
  </div>
</div>
