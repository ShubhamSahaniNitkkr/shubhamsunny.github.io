---
/** Decorative animated background for the hero — website / tech modernization theme */
---

<div class="hero-bg pointer-events-none absolute inset-0 z-0 overflow-hidden" aria-hidden="true">
  <div class="hero-bg-grid"></div>
  <div class="hero-bg-glow hero-bg-glow--left"></div>
  <div class="hero-bg-glow hero-bg-glow--right"></div>
  <div class="hero-bg-scan"></div>

  <svg class="hero-bg-wire hero-bg-wire--1" viewBox="0 0 200 140" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect x="1" y="1" width="198" height="138" rx="6" stroke="currentColor" stroke-width="1.2" />
    <rect x="1" y="1" width="198" height="22" rx="6" fill="currentColor" fill-opacity="0.08" />
    <circle cx="14" cy="12" r="3" fill="currentColor" fill-opacity="0.35" />
    <circle cx="26" cy="12" r="3" fill="currentColor" fill-opacity="0.2" />
    <circle cx="38" cy="12" r="3" fill="currentColor" fill-opacity="0.2" />
    <rect x="16" y="38" width="72" height="8" rx="2" fill="currentColor" fill-opacity="0.12" />
    <rect x="16" y="54" width="120" height="6" rx="2" fill="currentColor" fill-opacity="0.08" />
    <rect x="16" y="66" width="100" height="6" rx="2" fill="currentColor" fill-opacity="0.06" />
    <rect x="16" y="90" width="56" height="20" rx="3" fill="currentColor" fill-opacity="0.1" />
    <rect x="128" y="34" width="56" height="76" rx="4" stroke="currentColor" stroke-opacity="0.15" />
  </svg>

  <svg class="hero-bg-wire hero-bg-wire--2" viewBox="0 0 160 110" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect x="1" y="1" width="158" height="108" rx="5" stroke="currentColor" stroke-width="1.2" />
    <rect x="1" y="1" width="158" height="18" rx="5" fill="currentColor" fill-opacity="0.08" />
    <rect x="12" y="32" width="136" height="10" rx="2" fill="currentColor" fill-opacity="0.1" />
    <rect x="12" y="50" width="88" height="6" rx="2" fill="currentColor" fill-opacity="0.07" />
    <rect x="12" y="62" width="104" height="6" rx="2" fill="currentColor" fill-opacity="0.05" />
    <rect x="12" y="82" width="40" height="14" rx="3" fill="currentColor" fill-opacity="0.12" />
  </svg>

  <svg class="hero-bg-wire hero-bg-wire--3" viewBox="0 0 120 90" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect x="1" y="1" width="118" height="88" rx="4" stroke="currentColor" stroke-width="1" stroke-dasharray="4 3" />
    <text x="12" y="28" fill="currentColor" fill-opacity="0.2" font-family="monospace" font-size="10">&lt;/&gt;</text>
    <rect x="12" y="38" width="96" height="5" rx="1.5" fill="currentColor" fill-opacity="0.08" />
    <rect x="12" y="48" width="72" height="5" rx="1.5" fill="currentColor" fill-opacity="0.06" />
    <rect x="12" y="58" width="84" height="5" rx="1.5" fill="currentColor" fill-opacity="0.05" />
    <rect x="12" y="72" width="36" height="10" rx="2" fill="currentColor" fill-opacity="0.1" />
  </svg>

  <svg class="hero-bg-nodes" viewBox="0 0 800 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
    <g class="hero-bg-node-lines" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.12">
      <line x1="120" y1="180" x2="280" y2="120" />
      <line x1="280" y1="120" x2="520" y2="200" />
      <line x1="520" y1="200" x2="680" y2="140" />
      <line x1="280" y1="120" x2="340" y2="320" />
      <line x1="340" y1="320" x2="600" y2="380" />
      <line x1="120" y1="180" x2="200" y2="420" />
      <line x1="200" y1="420" x2="340" y2="320" />
    </g>
    <g class="hero-bg-node-dots" fill="currentColor">
      <circle class="hero-bg-dot" cx="120" cy="180" r="3" />
      <circle class="hero-bg-dot hero-bg-dot--delay-1" cx="280" cy="120" r="3.5" />
      <circle class="hero-bg-dot hero-bg-dot--delay-2" cx="520" cy="200" r="3" />
      <circle class="hero-bg-dot hero-bg-dot--delay-3" cx="680" cy="140" r="2.5" />
      <circle class="hero-bg-dot hero-bg-dot--delay-1" cx="340" cy="320" r="3" />
      <circle class="hero-bg-dot hero-bg-dot--delay-2" cx="600" cy="380" r="2.5" />
      <circle class="hero-bg-dot hero-bg-dot--delay-3" cx="200" cy="420" r="3" />
    </g>
  </svg>

  <div class="hero-bg-tags">
    <span class="hero-bg-tag hero-bg-tag--1">responsive</span>
    <span class="hero-bg-tag hero-bg-tag--2">performance</span>
    <span class="hero-bg-tag hero-bg-tag--3">SEO</span>
    <span class="hero-bg-tag hero-bg-tag--4">modern UI</span>
  </div>
</div>
