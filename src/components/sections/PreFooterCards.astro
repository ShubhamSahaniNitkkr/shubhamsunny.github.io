---
const cards = [
  {
    title: 'Projects',
    desc: 'Selected work (NDA-safe summaries)',
    href: '/projects',
    image: '/media/portfolio/massive-data-explorer/cover.jpg',
    accent: 'from-violet-600/90 to-violet-900/90',
  },
  {
    title: 'Templates',
    desc: 'New library coming — under review',
    href: '/templates',
    image: '/media/transformations/transform-2/after.jpg',
    accent: 'from-blue-600/90 to-blue-900/90',
  },
  {
    title: 'Products',
    desc: 'Custom tools built on client request',
    href: '/products',
    image: '/media/portfolio/sdui/cover.jpg',
    accent: 'from-orange-600/90 to-orange-900/90',
  },
  {
    title: 'Blog',
    desc: 'Guides & practical tips',
    href: '/blog',
    image: '/media/team/shubham.jpg',
    accent: 'from-emerald-600/90 to-emerald-900/90',
  },
];
---

<section class="border-t border-zinc-200 bg-white section-padding !pb-12 !pt-16 sm:!pb-16 sm:!pt-20">
  <div class="mx-auto max-w-7xl">
    <div class="mb-8 text-center sm:mb-10">
      <p class="section-eyebrow">Explore</p>
      <h2 class="section-title mt-2">More to discover</h2>
      <p class="section-subtitle mx-auto mt-2">Portfolio, templates, custom tools, and guides.</p>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4 lg:gap-5">
      {cards.map((card) => (
        <a
          href={card.href}
          class="group relative flex min-h-[200px] flex-col justify-end overflow-hidden rounded-2xl border border-zinc-200 shadow-md transition hover:-translate-y-1 hover:shadow-xl sm:min-h-[240px]"
        >
          <img
            src={card.image}
            alt=""
            class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-105"
            loading="lazy"
            width="800"
            height="480"
          />
          <div class={`absolute inset-0 bg-gradient-to-t ${card.accent} via-black/50 to-black/20`}></div>
          <div class="relative z-10 p-5 sm:p-6">
            <h3 class="font-display text-xl font-bold text-white sm:text-2xl">{card.title}</h3>
            <p class="mt-1 text-sm text-white/85">{card.desc}</p>
            <span class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-white/95 transition group-hover:gap-2">
              View all <span aria-hidden="true">→</span>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
