---
import media from '../../data/media.json';
import { getCloudinaryUrl } from '../../lib/utils';

const members = media.team;
---

<section id="team" class="bg-zinc-50 section-padding">
  <div class="mx-auto max-w-7xl">
    <div class="mx-auto max-w-3xl text-center">
      <p class="section-eyebrow">Our People</p>
      <h2 class="section-title mt-2">The talent behind every delivery</h2>
      <p class="section-subtitle mx-auto">
        A founder-led core team — development, QA, HR, and delivery.
        For larger builds we bring in trusted specialists we have worked with for years.
      </p>
    </div>

    <div class={`mt-10 grid gap-5 ${members.length === 1 ? 'mx-auto max-w-sm' : members.length === 2 ? 'sm:grid-cols-2 max-w-3xl mx-auto' : 'sm:grid-cols-2 lg:grid-cols-4'}`}>
      {members.map((member, idx) => {
        const img = member.image ? getCloudinaryUrl(member.image, 480, 480) : '';
        const phoneHref = member.phone ? `tel:${member.phone.replace(/\s/g, '')}` : '';
        const isPortrait = (member.image || '').match(/\.(jpe?g|webp)(\?|$)/i);
        return (
          <article class="glass-card overflow-hidden">
            <div class="relative aspect-square overflow-hidden bg-zinc-900">
              <img
                src={img || '/media/team/shubham.jpg'}
                alt={member.name}
                class={`h-full w-full ${isPortrait ? 'object-cover object-top' : 'object-contain object-center p-1'}`}
                loading="lazy"
                width="480"
                height="480"
              />
              {member.pastCompany && (
                <span class="absolute top-3 left-3 rounded-full bg-violet-600 px-2.5 py-1 text-[10px] font-bold uppercase text-white">{member.pastCompany}</span>
              )}
              {member.isFounder && (
                <span class="absolute top-3 right-3 rounded-full bg-amber-500 px-2.5 py-1 text-[10px] font-bold uppercase text-white">Founder</span>
              )}
              {member.certification && !member.isFounder && (
                <span class="absolute bottom-3 left-3 right-3 rounded-lg bg-black/55 px-2.5 py-1.5 text-center text-[10px] font-semibold text-white backdrop-blur-sm">{member.certification}</span>
              )}
            </div>
            <div class="p-5">
              <h3 class="font-display text-lg font-bold text-zinc-900">{member.name}</h3>
              <p class="text-sm font-medium text-violet-600">{member.role}</p>
              {member.expertise && member.expertise.length > 0 && (
                <div class="mt-2 flex flex-wrap gap-1">
                  {member.expertise.map((skill) => (
                    <span class="rounded-md bg-zinc-100 px-2 py-0.5 text-[10px] font-medium text-zinc-600">{skill}</span>
                  ))}
                </div>
              )}
              <p class="mt-3 line-clamp-4 text-xs leading-relaxed text-zinc-500">{member.bio}</p>
              <div class="mt-4 flex flex-wrap items-center gap-3">
                {member.phone && (
                  <a href={phoneHref} class="inline-flex items-center gap-1.5 text-xs font-semibold text-emerald-700 hover:text-emerald-800">
                    <span aria-hidden="true">📞</span>
                    {member.phone}
                  </a>
                )}
                {member.linkedin && (
                  <a href={member.linkedin} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-xs font-semibold text-violet-600 hover:text-violet-700">
                    LinkedIn →
                  </a>
                )}
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
