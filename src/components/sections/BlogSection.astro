---
import blog from '../../data/blog.json';
import type { BlogPost } from '../../types';

const posts = (blog as BlogPost[]).filter((p) => p.status === 'published').slice(0, 3);

function formatDate(iso: string) {
  if (!iso) return '';
  try {
    return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  } catch {
    return iso;
  }
}
---

<section id="blog" class="bg-zinc-50 section-padding">
  <div class="mx-auto max-w-7xl">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="section-eyebrow">Blog</p>
        <h2 class="section-title mt-2">Honest notes from the field</h2>
        <p class="section-subtitle mt-2 !mx-0 !max-w-xl">No fluff — what we see on real client projects, written for business owners.</p>
      </div>
      <a href="/blog" class="btn-ghost shrink-0 self-start sm:self-auto">All articles →</a>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => (
        <a href={`/blog/${post.slug}`} class="group flex flex-col overflow-hidden rounded-2xl border border-zinc-200 bg-white shadow-sm transition hover:-translate-y-0.5 hover:border-violet-200 hover:shadow-md">
          {post.image && (
            <div class="aspect-[16/10] overflow-hidden bg-zinc-100">
              <img src={post.image} alt="" class="h-full w-full object-cover transition duration-500 group-hover:scale-105" loading="lazy" width="600" height="375" />
            </div>
          )}
          <div class="flex flex-1 flex-col p-5 sm:p-6">
            <div class="flex flex-wrap items-center gap-2 text-[11px] font-medium text-zinc-500">
              {post.category && <span class="rounded-full bg-violet-50 px-2 py-0.5 text-violet-700">{post.category}</span>}
              {post.readTime && <span>{post.readTime}</span>}
              {post.publishDate && <span>· {formatDate(post.publishDate)}</span>}
            </div>
            <h3 class="mt-3 font-display text-lg font-bold leading-snug text-zinc-900 group-hover:text-violet-700">{post.title}</h3>
            <p class="mt-2 line-clamp-3 flex-1 text-sm leading-relaxed text-zinc-600">{post.excerpt}</p>
            <span class="mt-4 text-sm font-semibold text-violet-600">Read article →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
