---
import SectionTitle from '../ui/SectionTitle.astro';
import models from '../../data/models.json';
---

<section id="portfolio" class="portfolio-section relative overflow-hidden">
  <div class="portfolio-grain pointer-events-none absolute inset-0" aria-hidden="true"></div>
  <div class="relative z-10 container-salon section-padding">
    <SectionTitle label="Work" title="Recent Projects" subtitle="A preview of what I build — full portfolio on the projects page." light={true} />
    <div class="grid gap-5 sm:grid-cols-2">
      {models.models.slice(0, 4).map((project) => (
        <article class="salon-card border-white/10 bg-white/5 p-6 text-ivory">
          <p class="text-[10px] tracking-widest text-rose-gold-light uppercase">{project.clientIndustry || project.category}</p>
          <h3 class="font-display mt-2 text-xl font-semibold">{project.title}</h3>
          <p class="mt-2 text-sm text-ivory/70">{project.outcome}</p>
        </article>
      ))}
    </div>
    <div class="mt-10 text-center">
      <a href="/projects" class="btn-secondary !border-ivory/30 !text-ivory hover:!border-rose-gold-light">View All Projects</a>
    </div>
  </div>
</section>
