---
import media from '../../data/media.json';
import site from '../../data/site.json';
import social from '../../data/social.json';
import { siteConfig, getConsultationEmailUrl } from '../../lib/utils';
import HeroBackground from '../ui/HeroBackground.astro';
import HeroRotatingText from '../ui/HeroRotatingText';
import ReviewsMarquee from '../ui/ReviewsMarquee';

const hero = media.hero;
---

<section class="hero-section relative flex min-h-[100dvh] flex-col overflow-hidden">
  <HeroBackground />

  <div class="hero-main relative z-10 flex flex-[7] flex-col items-center justify-center px-5 py-8 text-center sm:px-6 sm:py-10">
    <p class="label">{hero.overline}</p>
    <div class="divider mx-auto mt-3"></div>
    <h1 class="font-display mt-4 max-w-4xl text-[1.85rem] font-semibold leading-[1.12] sm:text-4xl lg:text-[3.5rem]">
      <span class="hero-shimmer">{hero.titleLine1}</span><br />
      <HeroRotatingText client:load />
    </h1>
    <p class="mx-auto mt-4 max-w-lg text-sm font-medium text-muted sm:text-base">
      {siteConfig.stats.yearsExperience}+ years · {siteConfig.stats.projectsDelivered}+ projects · Trusted worldwide
    </p>
    {hero.philosophy && (
      <blockquote class="mx-auto mt-4 max-w-md border-l-2 border-rose-gold/50 pl-3 text-left text-xs italic text-muted sm:text-sm">
        &ldquo;{hero.philosophy}&rdquo;
      </blockquote>
    )}
    <p class="mx-auto mt-3 max-w-xl text-xs leading-relaxed text-muted-light sm:text-sm">{hero.description}</p>
    <div class="mt-7 flex w-full max-w-md flex-col gap-3 sm:mt-8 sm:max-w-none sm:flex-row sm:justify-center">
      <a href={getConsultationEmailUrl()} target="_blank" rel="noopener noreferrer" class="btn-primary hero-cta-pulse">
        Free Website Review
      </a>
      <a href="#transformations" class="btn-secondary">See Before & After</a>
    </div>
  </div>

  <div id="reviews" class="hero-marquee-band relative z-10 flex flex-[3] flex-col justify-end border-t border-champagne/80 bg-gradient-to-b from-ivory to-ivory-dark pb-3">
    <div class="mx-auto mb-3 flex flex-wrap items-center justify-center gap-2 px-4 sm:mb-4 sm:gap-4">
      <div class="salon-card px-3 py-2 sm:px-5 sm:py-3">
        <p class="font-display text-lg font-semibold text-charcoal sm:text-2xl">★ {site.stats.googleRating}</p>
        <p class="text-[9px] tracking-widest text-muted uppercase sm:text-[10px]">Average rating</p>
      </div>
      <div class="salon-card px-3 py-2 sm:px-5 sm:py-3">
        <p class="font-display text-lg font-semibold text-charcoal sm:text-2xl">{site.stats.happyClients}+</p>
        <p class="text-[9px] tracking-widest text-muted uppercase sm:text-[10px]">Happy clients</p>
      </div>
      <div class="salon-card px-3 py-2 sm:px-5 sm:py-3">
        <p class="font-display text-lg font-semibold text-charcoal sm:text-2xl">{site.stats.yearsExperience}+</p>
        <p class="text-[9px] tracking-widest text-muted uppercase sm:text-[10px]">Years experience</p>
      </div>
    </div>
    {social.fiverr.url && (
      <p class="mb-2 text-center text-[10px] text-muted sm:text-xs">
        <a href={social.fiverr.url} target="_blank" rel="noopener noreferrer" class="underline hover:text-rose-gold-dark">View all reviews on Fiverr →</a>
      </p>
    )}
    <ReviewsMarquee client:load />
  </div>
</section>
