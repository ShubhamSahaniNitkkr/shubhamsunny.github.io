---
import SectionTitle from '../ui/SectionTitle.astro';
import blog from '../../data/blog.json';
import type { BlogPost } from '../../types';

const posts = (blog as BlogPost[]).filter((p) => p.status === 'published').slice(0, 3);
---

<section id="blog" class="section-padding bg-surface-alt">
  <div class="container-salon">
    <SectionTitle label="Insights" title="From the Blog" subtitle="Plain-English tips for business owners." />
    <div class="grid gap-5 sm:grid-cols-3">
      {posts.map((post) => (
        <a href={`/blog/${post.slug}`} class="salon-card block p-6 transition hover:shadow-lg">
          <p class="text-[10px] tracking-widest text-muted uppercase">{post.publishDate}</p>
          <h3 class="font-display mt-3 text-lg font-semibold leading-snug">{post.title}</h3>
          <p class="mt-2 line-clamp-3 text-sm text-muted">{post.excerpt}</p>
          <span class="mt-4 inline-block text-xs font-semibold tracking-widest text-rose-gold-dark uppercase">Read →</span>
        </a>
      ))}
    </div>
    <div class="mt-8 text-center">
      <a href="/blog" class="btn-secondary">View All Articles</a>
    </div>
  </div>
</section>
