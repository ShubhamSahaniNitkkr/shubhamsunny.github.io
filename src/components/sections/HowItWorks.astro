---
import SectionTitle from '../ui/SectionTitle.astro';
---

<section id="process" class="section-padding bg-surface">
  <div class="container-salon">
    <SectionTitle label="Process" title="How It Works" subtitle="A clear, structured path from outdated site to polished online presence." />
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {[
        { step: '01', title: 'Free Review', desc: 'Share your current site. I audit design, mobile experience, and conversion — then recommend the right approach.' },
        { step: '02', title: 'Plan Together', desc: 'We align on scope, design direction, and timeline before any work begins.' },
        { step: '03', title: 'I Build It', desc: 'Design, development, and mobile optimization — with progress updates along the way.' },
        { step: '04', title: 'Launch', desc: 'Your new site goes live — fast, professional, and built to convert visitors.' },
      ].map((item) => (
        <article class="salon-card p-6">
          <p class="font-display text-3xl font-semibold text-rose-gold/40">{item.step}</p>
          <h3 class="font-display mt-3 text-lg font-semibold">{item.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted">{item.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>
