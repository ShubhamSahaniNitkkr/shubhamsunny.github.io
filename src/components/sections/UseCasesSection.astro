---
import UseCasesMarquee from '../ui/UseCasesMarquee';
import useCases from '../../data/use-cases.json';
---

<section id="use-cases" class="bg-white section-padding">
  <div class="mx-auto max-w-7xl">
    <div class="text-center">
      <p class="section-eyebrow">Use Cases</p>
      <h2 class="section-title mt-2">Example project scenarios</h2>
      <p class="section-subtitle mx-auto mt-2">Based on patterns from real client work — names and branding withheld under NDA. Tap any card for the full walkthrough.</p>
    </div>
    <div class="mt-10">
      <UseCasesMarquee client:visible items={useCases} />
    </div>
  </div>
</section>
