---
import ContactForm from './ContactForm';
import SectionBackdrop from '../ui/SectionBackdrop.astro';
import ContactFloatingReviews from '../ui/ContactFloatingReviews';
import notifications from '../../data/notifications.json';
import about from '../../data/about.json';

const contactQuote =
  about.contactQuote ||
  "I've been running this studio since 2018. If we take your project, you talk to real people — not a ticket queue — and get straight answers on timeline and cost.";
---

<SectionBackdrop
  id="contact"
  eyebrow="Contact Us"
  title="Let's talk about your project"
  subtitle="Tell us what you are building — we reply within one business day."
  image="https://images.unsplash.com/photo-1556761175-b413da4baf72?auto=format&fit=crop&w=1920&q=80"
  imageAlt="Team collaboration"
  overlay="from-violet-600/90 via-violet-800/80 to-violet-950/95"
>
  <ContactFloatingReviews client:visible slot="floating" />

  <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-2 lg:gap-16">
    <div>
      <div class="overflow-hidden rounded-2xl border border-white/20 bg-black/20 shadow-xl">
        <img
          src="/media/team/shubham.jpg"
          alt="Shubham Sunny — founder"
          class="mx-auto w-full max-h-72 object-contain object-top lg:max-h-80"
          loading="lazy"
          width="800"
          height="1000"
        />
      </div>

      <blockquote class="mt-6 rounded-2xl border border-white/15 bg-white/10 p-5 text-sm leading-relaxed text-white/95 backdrop-blur-sm">
        <p>{contactQuote}</p>
      </blockquote>

      <ul class="mt-5 space-y-3 text-sm">
        <li class="flex items-center gap-3 rounded-xl border border-zinc-200 bg-white p-3.5 text-zinc-800 shadow-lg">
          <span class="text-lg" aria-hidden="true">⚡</span>
          Fast response within 24 hours
        </li>
        <li class="flex items-center gap-3 rounded-xl border border-zinc-200 bg-white p-3.5 text-zinc-800 shadow-lg">
          <span class="text-lg" aria-hidden="true">🎯</span>
          Free initial consultation — no obligation
        </li>
      </ul>
    </div>
    <div id="contact-form" class="scroll-mt-28 rounded-2xl border border-zinc-200 bg-white p-6 shadow-xl sm:p-8">
      <ContactForm client:visible web3formsAccessKey={notifications.web3formsAccessKey} />
    </div>
  </div>
</SectionBackdrop>
