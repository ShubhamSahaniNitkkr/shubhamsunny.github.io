---
import SectionTitle from '../ui/SectionTitle.astro';
import ProjectsBento from '../ui/ProjectsBento';
---

<section id="portfolio" class="portfolio-section relative w-full overflow-hidden">
  <div class="portfolio-grain pointer-events-none absolute inset-0" aria-hidden="true"></div>
  <div class="relative z-10 w-full px-3 py-16 sm:px-5 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <SectionTitle
        label="Portfolio"
        title="Featured Projects"
        subtitle="Real builds across industries — each designed to look premium and perform on every device."
        light={true}
      />
    </div>
    <ProjectsBento client:load />
    <div class="mt-12 text-center">
      <a href="/projects" class="btn-secondary !border-ivory/30 !text-ivory hover:!border-rose-gold-light">Full project details</a>
    </div>
  </div>
</section>
