---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getConsultationEmailUrl } from '../lib/utils';
---

<BaseLayout title="Page Not Found" noindex={true}>
  <section class="flex min-h-[70vh] flex-col items-center justify-center px-4 text-center">
    <p class="label">404</p>
    <h1 class="font-display mt-4 text-4xl font-semibold">Page not found</h1>
    <p class="mt-3 text-muted">The page you are looking for does not exist.</p>
    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <a href="/" class="btn-primary">Go Home</a>
      <a href={getConsultationEmailUrl()} class="btn-email">Get in touch</a>
    </div>
  </section>
</BaseLayout>
