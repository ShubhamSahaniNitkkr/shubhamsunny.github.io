---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Transformations from '../components/sections/Transformations.astro';
import Team from '../components/sections/Team.astro';
import Packages from '../components/sections/Packages.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import PortfolioBento from '../components/sections/PortfolioBento.astro';
import FAQ from '../components/sections/FAQ.astro';
import Roadmap from '../components/sections/Roadmap.astro';
import BlogTeaser from '../components/sections/BlogTeaser.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import site from '../data/site.json';

const seo = site.seo || {};
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  keywords={seo.keywords}
  ogImage={seo.ogImage}
  canonical={`${site.domain}/`}
  schemaType="home"
>
  <Hero />
  <Transformations />
  <Team />
  <Packages />
  <HowItWorks />
  <PortfolioBento />
  <FAQ />
  <Roadmap />
  <BlogTeaser />
  <FinalCTA />
</BaseLayout>
