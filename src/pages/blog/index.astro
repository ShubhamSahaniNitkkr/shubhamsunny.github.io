---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../../components/ui/SectionTitle.astro';
import blog from '../../data/blog.json';
import site from '../../data/site.json';
import type { BlogPost } from '../types';

const posts = (blog as BlogPost[]).filter((p) => p.status === 'published');
---

<BaseLayout
  title={`Blog | ${site.brand}`}
  description="Plain-English insights on websites, mobile-friendly design, and growing your business online."
  canonical={`${site.domain}/blog`}
>
  <section class="section-padding bg-surface pt-28">
    <div class="container-salon">
      <SectionTitle label="Blog" title="Insights" subtitle="Tips for business owners — no tech jargon." />
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="salon-card block p-6 hover:shadow-lg">
            <p class="text-[10px] tracking-widest text-muted uppercase">{post.publishDate}</p>
            <h2 class="font-display mt-3 text-xl font-semibold">{post.title}</h2>
            <p class="mt-2 text-sm text-muted">{post.excerpt}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
