---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import PreFooterCards from '../components/sections/PreFooterCards.astro';
import ChatWidget from '../components/layout/ChatWidget';
import VisitTracker from '../components/layout/VisitTracker';
import CookieConsent from '../components/layout/CookieConsent';
import SchemaMarkup from '../components/seo/SchemaMarkup.astro';
import { siteConfig, getCloudinaryUrl } from '../lib/utils';
import media from '../data/media.json';
import notifications from '../data/notifications.json';
import type { SchemaPageType, BlogPostSchemaInput } from '../lib/schema';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: 'website' | 'article';
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleAuthor?: string;
  articleSection?: string;
  canonical?: string;
  schemaType?: SchemaPageType;
  pageTitle?: string;
  pageDescription?: string;
  serviceName?: string;
  serviceDescription?: string;
  blogPost?: BlogPostSchemaInput;
  blogPosts?: BlogPostSchemaInput[];
  noindex?: boolean;
}

const {
  title = siteConfig.seo?.title || `${siteConfig.brand} | ${siteConfig.tagline}`,
  description = siteConfig.seo?.description || siteConfig.tagline,
  keywords = siteConfig.seo?.keywords || 'website modernization',
  ogImage = siteConfig.seo?.ogImage || media.logo,
  ogImageAlt,
  ogType = 'website',
  articlePublishedTime,
  articleModifiedTime,
  articleAuthor,
  articleSection,
  canonical,
  schemaType = 'page',
  pageTitle,
  pageDescription,
  serviceName,
  serviceDescription,
  blogPost,
  blogPosts,
  noindex = false,
} = Astro.props;

const canonicalUrl = canonical || Astro.url.href;
const cacheVersion = media.settings.cacheVersion;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteConfig.domain}${ogImage}`;
const resolvedOgImageAlt = ogImageAlt || title;
const resolvedPageTitle = pageTitle || title;
const resolvedPageDescription = pageDescription || description;
const heroLcp = media.hero.rotation[0]?.src;
const heroPreload = heroLcp ? getCloudinaryUrl(heroLcp, 900, 1125) : undefined;
const notifyOnVisit = notifications.notifyOnVisit;
const chatbotEnabled = notifications.chatbotEnabled;
const web3formsAccessKey = notifications.web3formsAccessKey;
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content={siteConfig.brand} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
    <meta name="googlebot" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large'} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="application-name" content={siteConfig.brand} />
    <meta name="apple-mobile-web-app-title" content={siteConfig.brand} />
    <meta name="format-detection" content="telephone=yes" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.brand} Blog`} href="/blog/rss.xml" />
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLM Site Summary" />
    <link rel="alternate" type="text/plain" href="/llms-full.txt" title="LLM Full Site Details" />
    <link rel="alternate" type="text/plain" href="/ai.txt" title="AI Crawler Discovery" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#FFFFFF" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={resolvedOgImageAlt} />
    <meta property="og:site_name" content={siteConfig.brand} />
    <meta property="og:locale" content="en_US" />
    {ogType === 'article' && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {ogType === 'article' && articleModifiedTime && (
      <meta property="article:modified_time" content={articleModifiedTime} />
    )}
    {ogType === 'article' && articleAuthor && (
      <meta property="article:author" content={articleAuthor} />
    )}
    {ogType === 'article' && articleSection && (
      <meta property="article:section" content={articleSection} />
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={resolvedOgImageAlt} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href={getCloudinaryUrl('/media/team/shubham.jpg', 180, 180)} />
    {heroPreload && <link rel="preload" href={heroPreload} as="image" fetchpriority="high" />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <SchemaMarkup
      type={schemaType}
      serviceName={serviceName}
      serviceDescription={serviceDescription}
      pageUrl={canonical}
      pageTitle={resolvedPageTitle}
      pageDescription={resolvedPageDescription}
      blogPost={blogPost}
      blogPosts={blogPosts}
    />
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-white focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-violet-700 focus:shadow-lg focus:outline-none focus:ring-2 focus:ring-violet-500">
      Skip to main content
    </a>
    <VisitTracker client:idle enabled={notifyOnVisit} />
    <Header />
    <div class="site-content relative z-[1]">
      <main id="main-content">
        <slot />
      </main>
      <PreFooterCards />
      <Footer />
    </div>
    <ChatWidget client:idle enabled={chatbotEnabled} web3formsAccessKey={web3formsAccessKey} />
    <CookieConsent client:idle />
    <script define:vars={{ cacheVersion }}>
      if ('serviceWorker' in navigator) {
        if (/localhost|127\.0\.0\.1/.test(location.hostname)) {
          navigator.serviceWorker.getRegistrations().then((regs) => regs.forEach((r) => r.unregister()));
        } else {
          window.addEventListener('load', () => {
            navigator.serviceWorker.register(`/sw.js?v=${cacheVersion}`).catch(() => {});
          });
        }
      }
    </script>
  </body>
</html>
