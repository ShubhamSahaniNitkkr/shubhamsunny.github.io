---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import ExitIntentPopup from '../components/layout/ExitIntentPopup';
import ChatWidget from '../components/layout/ChatWidget';
import VisitTracker from '../components/layout/VisitTracker';
import SchemaMarkup from '../components/seo/SchemaMarkup.astro';
import { siteConfig, getCloudinaryUrl } from '../lib/utils';
import media from '../data/media.json';
import notifications from '../data/notifications.json';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  canonical?: string;
  schemaType?: 'home' | 'service';
  serviceName?: string;
  serviceDescription?: string;
  noindex?: boolean;
}

const {
  title = siteConfig.seo?.title || `${siteConfig.brand} | ${siteConfig.tagline}`,
  description = siteConfig.seo?.description || siteConfig.tagline,
  keywords = siteConfig.seo?.keywords || 'website modernization',
  ogImage = siteConfig.seo?.ogImage || media.logo,
  canonical,
  schemaType = 'home',
  serviceName,
  serviceDescription,
  noindex = false,
} = Astro.props;

const canonicalUrl = canonical || Astro.url.href;
const cacheVersion = media.settings.cacheVersion;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteConfig.domain}${ogImage}`;
const heroLcp = media.hero.rotation[0]?.src;
const heroPreload = heroLcp ? getCloudinaryUrl(heroLcp, 900, 1125) : undefined;
const notifyOnVisit = notifications.notifyOnVisit;
const chatbotEnabled = notifications.chatbotEnabled;
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content={siteConfig.brand} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large'} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="theme-color" content="#0F172A" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={siteConfig.brand} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLM Site Summary" />
    <link rel="alternate" type="text/plain" href="/llms-full.txt" title="LLM Full Site Details" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href={getCloudinaryUrl('/media/team/shubham.jpg', 180, 180)} />
    {heroPreload && <link rel="preload" href={heroPreload} as="image" fetchpriority="high" />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <SchemaMarkup type={schemaType} serviceName={serviceName} serviceDescription={serviceDescription} pageUrl={canonical} />
  </head>
  <body>
    <VisitTracker client:idle enabled={notifyOnVisit} />
    <Header />
    <div class="site-content relative z-[1]">
      <main>
        <slot />
      </main>
      <Footer />
    </div>
    <ChatWidget client:idle enabled={chatbotEnabled} />
    <ExitIntentPopup client:idle />
    <script define:vars={{ cacheVersion }}>
      if ('serviceWorker' in navigator) {
        if (/localhost|127\.0\.0\.1/.test(location.hostname)) {
          navigator.serviceWorker.getRegistrations().then((regs) => regs.forEach((r) => r.unregister()));
        } else {
          window.addEventListener('load', () => {
            navigator.serviceWorker.register(`/sw.js?v=${cacheVersion}`).catch(() => {});
          });
        }
      }
    </script>
  </body>
</html>
