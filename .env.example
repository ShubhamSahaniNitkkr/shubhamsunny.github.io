# Cloudinary — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Nodemailer — chatbot + visit notifications (Vercel/server deploy only)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=your@gmail.com
NOTIFY_EMAIL=your@gmail.com

# Optional: Vercel API URL when static site is on GitHub Pages
# PUBLIC_API_URL=https://your-project.vercel.app

# Optional: Web3Forms key for chat email on static hosting (https://web3forms.com)
PUBLIC_WEB3FORMS_ACCESS_KEY=your_access_key
